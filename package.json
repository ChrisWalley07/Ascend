{
  "name": "ascend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "prisma generate && next dev --hostname 127.0.0.1 --port 3004",
    "dev:clean": "lsof -ti :3004 | xargs kill -9 2>/dev/null; lsof -ti :3005 | xargs kill -9 2>/dev/null; lsof -ti :3006 | xargs kill -9 2>/dev/null; lsof -ti :3007 | xargs kill -9 2>/dev/null; rm -rf .next && prisma generate && next dev --hostname 127.0.0.1 --port 3004",
    "dev:restart": "npm run dev:clean",
    "dev:webpack": "prisma generate && next dev --webpack --hostname 127.0.0.1 --port 3004",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:sync": "prisma generate && prisma db push && npm run db:migrate-sql",
    "db:migrate-sql": "prisma db execute --file prisma/sql/sport-migration.sql && prisma db execute --file prisma/sql/sport-migration-enum-fix.sql && prisma db execute --file prisma/sql/pb-sport-migration.sql && prisma db execute --file prisma/sql/weekly-snapshot-migration.sql && prisma db execute --file prisma/sql/catalog-achievement-migration.sql",
    "prisma:migrate-sport": "prisma db execute --file prisma/sql/sport-migration.sql",
    "prisma:migrate-sport-enum": "prisma db execute --file prisma/sql/sport-migration-enum-fix.sql",
    "prisma:migrate-pb-sport": "prisma db execute --file prisma/sql/pb-sport-migration.sql",
    "prisma:migrate-weekly-snapshot": "prisma db execute --file prisma/sql/weekly-snapshot-migration.sql",
    "prisma:migrate-catalog-achievements": "prisma db execute --file prisma/sql/catalog-achievement-migration.sql",
    "test:achievements": "node --import tsx --test features/athlete-achievements/engine/evaluate-engine.test.ts features/athlete-achievements/xp/progression.test.ts features/athlete-achievements/collectors/streak.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/papaparse": "^5.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
